# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# EIA Open Data API key (https://www.eia.gov/opendata/)
EIA_API_KEY=your_eia_api_key_here

# Optional overrides (defaults shown)
# WEATHER_API_URL=https://archive-api.open-meteo.com/v1/archive
# MLFLOW_EXPERIMENT_NAME=Energy_Consumption_Forecasting
# MLFLOW_TRACKING_URI=sqlite:///mlruns.db
# Set MLFLOW_TRACKING_URI to a fixed absolute path so all scripts and
# notebooks write to the same store regardless of working directory.
# Without it, MLflow defaults to a local mlruns/ folder in CWD, which
# causes notebooks to create a separate DB under notebooks/.
